# ─── Required ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# RapidAPI injects this header automatically on every request.
# Get it from: RapidAPI Dashboard > My APIs > ResumeAI API > Security
RAPIDAPI_PROXY_SECRET=your-rapidapi-proxy-secret-here

# ─── Optional (defaults shown) ────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
MAX_FILE_SIZE_MB=5
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
LOG_LEVEL=info
